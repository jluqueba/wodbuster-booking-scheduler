# Example environment file for local development.
#
# Copy to `.env` at the repo root and adjust values as needed. Never
# commit a real `.env`: it is excluded by `.gitignore` and by
# `.dockerignore`. Secrets do not belong in this file even in prod;
# they live in Azure Key Vault (ADR-0005) and are surfaced to the
# Container App via Key Vault references. Secret entries below are
# intentionally left without a value.
#
# Variable names must match the `Settings` fields in
# `src/wodbuster_worker/config.py` (pydantic maps them case-insensitively
# with no prefix). Unknown names are silently ignored.

# ---------------------------------------------------------------------------
# Runtime mode
# ---------------------------------------------------------------------------

# Which mode the worker runs in. `local` reads from this file and from
# the process environment. `prod` is wired by Container Apps and
# resolves secrets via Key Vault references (F4.4).
WODBUSTER_ENV=local

# Root log level for structlog. One of DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Public base URL the worker is reachable at. Optional locally;
# required in prod for OAuth callbacks and Telegram deep links. Leave
# unset locally unless you are testing OAuth flows against a tunnel.
# APP_BASE_URL=https://localhost:8000

# Timezone in which every HH:MM value on a scheduler rule is
# interpreted. Defaults to the single-user deployment (Spain).
WORKER_TIMEZONE=Europe/Madrid

# ---------------------------------------------------------------------------
# Postgres connection (ADR-0002)
# ---------------------------------------------------------------------------
# Defaults match the docker-compose service in `docker-compose.yml`. In
# prod, Container Apps injects POSTGRES_HOST/PORT/DB/USER pointing at the
# Flexible Server; the password is unused because the worker
# authenticates with an Entra token acquired via the runtime UAMI
# (ADR-0005).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wodbuster
POSTGRES_USER=wodbuster
POSTGRES_PASSWORD=wodbuster

# ---------------------------------------------------------------------------
# WodBuster tenant coordinates (US-003, US1.1)
# ---------------------------------------------------------------------------
# `gym` is the subdomain slug (e.g. antworktrainingcenter); `idu` is the
# operator's stable identifier found in every /athlete/handlers/* URL.
# Both are non-secret. The client build site fails loudly if a WodBuster
# call is attempted before they are set.
WODBUSTER_GYM=
WODBUSTER_IDU=

# ---------------------------------------------------------------------------
# OAuth client IDs (non-secret, operator-specific)
# ---------------------------------------------------------------------------
# Public identifiers of the registered OAuth apps. Not secret, but
# deployment-specific, so left blank here. `auth.oauth.build_oauth`
# skips a provider whose client id (or secret) is missing.
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# Session lifetime knobs (US-009)
# ---------------------------------------------------------------------------
# `idle` closes a session dormant for N minutes; `absolute` caps total
# lifetime regardless of activity.
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=24

# ---------------------------------------------------------------------------
# Heartbeat knobs (US-004)
# ---------------------------------------------------------------------------
# Upper bound (days) on the pessimistic cookie TTL projection.
COOKIE_PROJECTED_TTL_CEILING_DAYS=30

# ---------------------------------------------------------------------------
# Key Vault (prod only)
# ---------------------------------------------------------------------------
# Optional locally (secrets come from this file); required in prod, where
# `security.keyvault.load_secrets` resolves the operator secrets.
# KEY_VAULT_URL=https://<vault-name>.vault.azure.net/

# ---------------------------------------------------------------------------
# Observability (optional locally)
# ---------------------------------------------------------------------------
# Service name reported to OpenTelemetry.
OTEL_SERVICE_NAME=wodbuster-worker
# Application Insights connection string (contains an instrumentation
# key). Secret; leave blank locally unless exporting telemetry.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---------------------------------------------------------------------------
# Secrets (no value here; sourced from Key Vault in prod, filled in the
# real local .env)
# ---------------------------------------------------------------------------

# Base64 Fernet key used to encrypt the WodBuster session cookie at rest.
COOKIE_ENCRYPTION_KEY=

# Secret used to sign/encrypt the operator's web session.
SESSION_ENCRYPTION_SECRET=

# Telegram bot token issued by BotFather.
TELEGRAM_BOT_TOKEN=

# Shared secret validating inbound Telegram webhook calls.
TELEGRAM_WEBHOOK_SECRET=

# OAuth client secrets for each identity provider.
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_SECRET=

# Healthchecks.io ping URL (embeds a capability token; treat as secret).
HEALTHCHECKS_PING_URL=
