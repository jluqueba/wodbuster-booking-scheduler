# Example environment file for local development.
#
# Copy to `.env` at the repo root and adjust values as needed. Never
# commit a real `.env`: it is excluded by `.gitignore` and by
# `.dockerignore`. Secrets do not belong in this file even in prod;
# they live in Azure Key Vault (ADR-0005) and are surfaced to the
# Container App via Key Vault references.

# Which mode the worker runs in. `local` reads from this file and from
# the process environment. `prod` is wired by Container Apps and
# resolves secrets via Key Vault references (F4.4).
WODBUSTER_ENV=local

# Postgres connection (ADR-0002). Defaults match the docker-compose
# service in `docker-compose.yml`. In prod, Container Apps injects
# POSTGRES_HOST/PORT/DB/USER pointing at the Flexible Server; the
# password is unused because the worker authenticates with an Entra
# token acquired via the runtime UAMI (ADR-0005).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wodbuster
POSTGRES_USER=wodbuster
POSTGRES_PASSWORD=wodbuster

# Root log level for structlog. One of DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Public base URL the worker is reachable at. Optional locally;
# required in prod for OAuth callbacks and Telegram deep links. Leave
# unset locally unless you are testing OAuth flows against a tunnel.
# APP_BASE_URL=https://localhost:8000
