{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "operatorPrincipalId": {
      "value": "${AZURE_OPERATOR_PRINCIPAL_ID=}"
    },
    "operatorPrincipalUpn": {
      "value": "${AZURE_OPERATOR_PRINCIPAL_UPN}"
    },
    "deployPrincipalId": {
      "value": "${AZURE_DEPLOY_PRINCIPAL_ID=}"
    },
    "operatorFirewallCidr": {
      "value": "${AZURE_OPERATOR_FIREWALL_CIDR=}"
    },
    "acaOutboundIps": {
      "value": "${AZURE_ACA_ENVIRONMENT_OUTBOUND_IPS=[]}"
    },
    "oauthMicrosoftClientId": {
      "value": "${OAUTH_MICROSOFT_CLIENT_ID=}"
    },
    "oauthGithubClientId": {
      "value": "${OAUTH_GITHUB_CLIENT_ID=}"
    },
    "oauthGoogleClientId": {
      "value": "${OAUTH_GOOGLE_CLIENT_ID=}"
    },
    "wodbusterGym": {
      "value": "${WODBUSTER_GYM=}"
    },
    "wodbusterIdu": {
      "value": "${WODBUSTER_IDU=}"
    },
    "containerImage": {
      "value": "${SERVICE_WORKER_IMAGE_NAME=}"
    }
  }
}
