# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version

# Ephemeral tooling artifacts created by the agent when it prepares
# multi-line PR bodies or commit messages. Never intended for VCS.
.pr-body.md
.commit-msg.txt

# Local SQLite artifacts (WAL, SHM, journal, and hand-run ad-hoc DBs).
*.db
*.db-journal
*.db-wal
*.db-shm

# Editor and OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Bicep build artifacts (produced by `az bicep build`).
# main.parameters.json is a real source file; only main.json is generated.
infra/main.json

# Spike artifacts that may contain credentials, session material, or PII.
# See docs/features/phase-0-api-discovery/scripts/README.md for the rationale.
# These patterns are intentionally broad. When in doubt, do not commit.
.env
.env.*
!.env.example
cookies.txt
*.cookiejar
*.session
*.har
booking-payload.json
booking-payload.*.json
spike-capture-*.txt
spike-output-*.log
